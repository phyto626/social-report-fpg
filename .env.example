# ===== 多品牌 Facebook API 設定 =====
# Graph API 版本（共用）
FB_API_VERSION=v21.0

# ----- 台塑便利家 -----
FPG_PAGE_ID=你的粉專ID
FPG_ACCESS_TOKEN=你的
FPG_BRAND_NAME=台塑便利家

# ----- ECOCO -----
ECOCO_PAGE_ID=你的粉專ID
ECOCO_ACCESS_TOKEN=你的權杖
ECOCO_BRAND_NAME=ECOCO

# ===== 輸出設定 =====
OUTPUT_DIR=./output
EXPORT_EXCEL=true
