# ===== Facebook API 設定 =====
# 粉專 Page ID（在粉專「關於」頁面可找到）
FB_PAGE_ID=你的粉專ID

# Page Access Token（長期權杖）
# 取得方式：Meta Developer > 你的應用程式 > Graph API Explorer > 產生權杖
FB_PAGE_ACCESS_TOKEN=你的權杖

# Graph API 版本（預設 v21.0）
FB_API_VERSION=v21.0

# ===== 品牌設定 =====
BRAND_NAME=洗衣精補充站

# ===== 輸出設定 =====
# 報告輸出資料夾
OUTPUT_DIR=./output

# 是否同時匯出 Excel 檔案（true/false）
EXPORT_EXCEL=true
